{
  "dependencies": {
    "upgrade": "^1.1.0"
  },
  "devDependencies": {
    "livereload": "^0.10.2",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.2.0"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-jinja-template"
    ],
    "overrides": [
      {
        "endOfLine": "lf",
        "files": "*.html",
        "options": {
          "parser": "jinja-template",
          "tabWidth": 2,
          "semi": true,
          "trailingComma": "es5",
          "singleQuote": true,
          "bracketSameLine": true
        }
      }
    ]
  }
}
